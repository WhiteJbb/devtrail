#!/bin/sh
# devtrail post-commit hook
# Captures git commit to Obsidian vault automatically.
# Install via: devtrail install-hooks --repo <path>
#
# [비활성화] 커밋마다 LLM을 호출해 GitSummaries에 노트를 생성하는 방식이었으나
# 두 가지 문제로 제거:
#   1. 커밋마다 LLM 호출 → 커밋 속도 저하 (수 초 블로킹)
#   2. diff가 800자로 잘려 LLM이 실질적으로 커밋 메시지만 재해석 → 정보 품질 낮음
# nightly-distill이 session 노트 기반으로 하루치를 한 번에 처리하는 것으로 대체.
# capture-commit CLI 명령 자체는 app/agents/capture_agent.py에 보존돼 있음.
exit 0

DEVTRAIL_HOME=$(git config --local devtrail.home 2>/dev/null)
[ -z "$DEVTRAIL_HOME" ] && exit 0

PYTHON=$(git config --local devtrail.python 2>/dev/null)
[ -z "$PYTHON" ] && PYTHON="python"

PROJECT=$(git config --local devtrail.project 2>/dev/null)
[ -z "$PROJECT" ] && PROJECT=$(basename "$(git rev-parse --show-toplevel)")

REPO=$(git rev-parse --show-toplevel)

# feat: / refactor: / fix: 커밋만 캡처
SUBJECT=$(git log -1 --format=%s)
case "$SUBJECT" in
  feat:*|refactor:*|fix:*) ;;
  *) exit 0 ;;
esac

# Convert Windows backslashes to forward slashes for Git Bash
DEVTRAIL_HOME_UNIX=$(echo "$DEVTRAIL_HOME" | tr '\\' '/')

cd "$DEVTRAIL_HOME_UNIX" && \
  "$PYTHON" -m app.cli capture-commit --repo "$REPO" --project "$PROJECT" --from-agent 2>/dev/null \
  && echo "[devtrail] captured -> $PROJECT" \
  || true
