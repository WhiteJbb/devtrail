# ===== LLM =====
# 사용할 provider: "openai_compatible" 또는 "ollama". 비워두면 LLM 미설정 상태(초안 생성 시 안내).
LLM_PROVIDER=

# Wiki Core routing 목표. 현재 Phase 1~3에서는 설정만 보존하고, 실제 provider 라우팅은 이후 Phase에서 연결한다.
LOCAL_LLM_PROVIDER=ollama
WRITER_PROVIDER=gemini

# --- openai_compatible provider (vLLM / OpenAI / Ollama의 /v1 엔드포인트 공통) ---
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ollama 네이티브 provider ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# --- Gemini writer provider (Phase 4+에서 글쓰기 모델 라우팅에 연결 예정) ---
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# LLM 컨텍스트 예산(문자 수). 수집한 source를 이 한도로 잘라 프롬프트에 넣는다.
CONTEXT_CHAR_BUDGET=12000
# LLM HTTP 시도 횟수(1=재시도 없음). 일시적 오류/5xx에 지수 백오프 재시도.
LLM_MAX_RETRIES=2
DEFAULT_TIMEZONE=Asia/Seoul

# ===== Notion (legacy optional) =====
# 기존 Blog DB 상태 추적 연동. 새 중심은 Obsidian이며, 이 값을 false로 두면 키가 있어도 mock으로 동작한다.
LEGACY_NOTION_ENABLED=false
NOTION_API_KEY=
NOTION_BLOG_DATABASE_ID=
NOTION_IDEA_DATABASE_ID=
NOTION_WORKLOG_DATABASE_ID=
# 초안 소스로 본문을 읽어올 Notion 페이지 id(쉼표 구분). "정리해 둔 문서"를 직접 가리킬 때.
NOTION_SOURCE_PAGE_IDS=

# ===== Obsidian =====
# 새 권장 이름. 비우면 Obsidian Wiki Core 명령은 비활성.
OBSIDIAN_VAULT_PATH=
# 기존 호환 이름. 새 설정에서는 OBSIDIAN_VAULT_PATH를 우선 사용한다.
OBSIDIAN_VAULT_DIR=
# 읽을 노트를 태그로 필터링(쉼표 구분). 비우면 전체 노트.
OBSIDIAN_TAGS=blog-idea,worklog
# 읽을 노트를 폴더로 필터링(쉼표 구분, 볼트 기준 상대경로). 비우면 볼트 전체.
OBSIDIAN_FOLDERS=
# 기존 LLM wiki 실험 명령(wiki-ingest/wiki-query)이 사용하는 내부 wiki 폴더.
WIKI_FOLDER=60_Wiki

# ===== Paths (보통 수정 불필요) =====
WORKSPACE_DIR=workspace

# ===== Git source =====
# suggest-topics / write-draft가 참고할 최근 커밋 수
GIT_LOG_LIMIT=20
# 초안 근거로 커밋 diff 일부를 포함할지, 커밋당 diff 최대 문자 수
GIT_INCLUDE_DIFF=true
GIT_DIFF_MAX_CHARS=800

# ===== Messenger (선택) =====
# 비우면 봇 비활성. 양방향 봇을 쓰려면 telegram으로 설정.
MESSENGER_PROVIDER=
TELEGRAM_BOT_TOKEN=
# 봇에 명령할 수 있는 chat id(쉼표 구분). 본인 id로 제한 권장.
TELEGRAM_ALLOWED_CHAT_IDS=
# 알림(outbound)을 보낼 기본 chat id.
TELEGRAM_CHAT_ID=
