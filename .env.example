# ===== LLM =====
# 최종 폴백 provider. "openai_compatible", "ollama", "gemini" 중 하나.
LLM_PROVIDER=gemini

# 분류·라우팅·짧은 요약용 provider (로컬 LLM 미사용 시 gemini lite로 폴백)
LOCAL_LLM_PROVIDER=ollama
# 글쓰기·초안·정제용 provider
WRITER_PROVIDER=gemini

# --- openai_compatible provider (vLLM / OpenAI / Ollama의 /v1 엔드포인트 공통) ---
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ollama 네이티브 provider ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# --- Gemini provider ---
GEMINI_API_KEY=
GEMINI_LITE_MODEL=gemini-2.5-flash-lite   # 로컬 LLM 폴백 시 사용
GEMINI_FLASH_MODEL=gemini-2.5-flash       # 글쓰기용

# LLM 컨텍스트 예산(문자 수). 수집한 source를 이 한도로 잘라 프롬프트에 넣는다.
CONTEXT_CHAR_BUDGET=12000
# LLM HTTP 시도 횟수(1=재시도 없음). 일시적 오류/5xx에 지수 백오프 재시도.
LLM_MAX_RETRIES=2
# LLM HTTP 타임아웃(초)
LLM_TIMEOUT=300

# ===== Obsidian =====
OBSIDIAN_VAULT_PATH=
WIKI_FOLDER=60_Wiki

# ===== Git source =====
GIT_LOG_LIMIT=20
GIT_INCLUDE_DIFF=true
GIT_DIFF_MAX_CHARS=800

# ===== Messenger (선택) =====
# 비우면 봇 비활성. 양방향 봇을 쓰려면 telegram으로 설정.
MESSENGER_PROVIDER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHAT_ID=
